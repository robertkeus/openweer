# Production .env for OpenWeer.
# Copy to /opt/openweer/.env on the VM, fill in real values, chmod 600.
# NEVER commit this file.

# ---- KNMI Open Data Platform (https://developer.dataplatform.knmi.nl) ----
KNMI_OPEN_DATA_API_KEY=
KNMI_NOTIFICATION_API_KEY=
KNMI_EDR_API_KEY=
KNMI_WMS_API_KEY=

# ---- LLM provider for /api/chat ----
OPENWEER_GREENPT_API_KEY=
OPENWEER_GREENPT_MODEL=gemma4

# ---- Runtime ----
OPENWEER_LOG_LEVEL=INFO
OPENWEER_DATA_DIR=/data

# ---- Public URLs ----
PUBLIC_SITE_URL=https://openweer.nl

# ---- Caddy / TLS ----
# Comma-separated hostnames Caddy should serve (and auto-issue certs for).
OPENWEER_SITE_HOST=openweer.nl, www.openweer.nl
# Email Let's Encrypt contacts on cert-renewal failures.
OPENWEER_ACME_EMAIL=mail@greenpt.ai
