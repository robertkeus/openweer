# OpenWeer Caddyfile
# Host is driven by env: dev defaults to `:80` (no TLS), prod sets
# OPENWEER_SITE_HOST="openweer.nl, www.openweer.nl" so Caddy auto-issues
# Let's Encrypt certs. Email goes to OPENWEER_ACME_EMAIL.

{
	# Disable the admin API in prod — local-only by default.
	admin off
	# Let's Encrypt contact (only in prod, dev default is empty).
	email {$OPENWEER_ACME_EMAIL:}
	# Sensible defaults for served static files.
	servers {
		trusted_proxies static private_ranges
	}
	# Rate-limit module ordering — must come before reverse_proxy.
	order rate_limit before reverse_proxy
}

{$OPENWEER_SITE_HOST::80} {
	# ---- Security headers (OWASP A05) — applied to every response ----
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=()"
		Cross-Origin-Opener-Policy "same-origin"
		# Hide upstream banners.
		-Server
	}

	# ---- Pre-rendered radar tiles (served straight from the bind-mount) ----
	# Bypasses the API entirely. CDN-friendly cache headers.
	@tiles path /tiles/*
	handle @tiles {
		root * /var/openweer
		header Cache-Control "public, max-age=300, stale-while-revalidate=900"
		header Content-Security-Policy "default-src 'none'; img-src 'self'"
		file_server
	}

	# ---- API → FastAPI ----
	# Rate-limit per client IP (OWASP A01) — generous for normal browser
	# use but blunts scraper / abuse traffic before it hits FastAPI.
	@api path /api/*
	handle @api {
		rate_limit {
			zone api_per_ip {
				key {client_ip}
				events 120
				window 1m
			}
		}
		reverse_proxy api:8000 {
			# Stream SSE responses (POST /api/chat) byte-by-byte
			# instead of letting Caddy buffer the proxy response.
			# Without this the browser sits at "0 bytes received" for
			# the whole chat completion duration and our frontend
			# renders "De AI-assistent kon je vraag niet beantwoorden."
			# Negative values flush after every write.
			flush_interval -1
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# ---- Static favicon (a quick win for first paint) ----
	@favicon path /favicon.svg /favicon.ico
	handle @favicon {
		header Cache-Control "public, max-age=86400"
		reverse_proxy web:3000
	}

	# ---- Everything else → React Router SSR server ----
	handle {
		# CSP for the SSR'd app:
		# - script-src needs 'unsafe-inline' because React Router v7 emits
		#   inline hydration <script> tags; without it the app never
		#   hydrates and client components (e.g. the map) never mount.
		#   Tightening this requires per-request nonces wired through RR.
		# - worker-src must allow blob: — MapLibre instantiates its
		#   tile-parser worker from URL.createObjectURL(new Blob([...])).
		# - img-src allows blob: for MapLibre's canvas-to-image internals.
		header Content-Security-Policy "default-src 'self'; img-src 'self' data: blob: https://tiles.openfreemap.org https://*.amazonaws.com https://basemaps.cartocdn.com https://*.basemaps.cartocdn.com; script-src 'self' 'unsafe-inline'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://tiles.openfreemap.org https://nominatim.openstreetmap.org https://basemaps.cartocdn.com https://*.basemaps.cartocdn.com; frame-ancestors 'none'; base-uri 'self'"
		reverse_proxy web:3000 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Compress text-ish responses. Explicitly list types so we *exclude*
	# `text/event-stream` — gzip/zstd both need to buffer input before
	# they can emit, which kills the per-chunk streaming the SSE chat
	# endpoint relies on (the browser sits at "0 bytes received" until
	# the whole answer is done). The default `text/*` match would
	# silently sweep SSE in too.
	encode {
		gzip
		zstd
		match {
			header Content-Type application/json*
			header Content-Type application/javascript*
			header Content-Type application/xhtml+xml*
			header Content-Type text/css*
			header Content-Type text/html*
			header Content-Type text/plain*
			header Content-Type text/xml*
			header Content-Type image/svg+xml*
		}
	}
	log {
		format json
		output stdout
	}
}
