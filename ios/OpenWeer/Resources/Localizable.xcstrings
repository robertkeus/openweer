    "about_build.data_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rain comes from KNMI's open radar data (HDF5, refreshed every 5 minutes). Longer forecasts use the HARMONIE-AROME hourly model. Both are published by KNMI under the CC BY 4.0 license — OpenWeer is not part of KNMI."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De regen komt uit KNMI's open radardata (HDF5, elke 5 minuten ververst). Voor langere voorspellingen gebruiken we het HARMONIE-AROME uurmodel. Beide zijn door het KNMI gepubliceerd onder de CC BY 4.0-licentie — OpenWeer is geen onderdeel van het KNMI."
          }
        }
      }
    },
    "about_build.data_heading" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data"
          }
        }
      }
    },
    "about_build.intro" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A short look behind the scenes of OpenWeer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een korte blik achter de schermen van OpenWeer."
          }
        }
      }
    },
    "about_build.opensource_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenWeer is open source under the MIT license. The full codebase — backend, web app and iOS app — is on GitHub at github.com/robertkeus/openweer. Feedback and contributions are welcome."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenWeer is open source onder de MIT-licentie. De volledige broncode — backend, webapp en iOS-app — staat op GitHub op github.com/robertkeus/openweer. Feedback en bijdragen zijn welkom."
          }
        }
      }
    },
    "about_build.opensource_heading" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open source"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open source"
          }
        }
      }
    },
    "about_build.stack_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The backend is a FastAPI service in Python that processes KNMI data and serves a small public API. The iOS app is written in SwiftUI; the web app uses React Router v7 with MapLibre for the radar map. Everything runs in Docker on a single Linux server."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De backend is een FastAPI-service in Python die KNMI-data verwerkt en een kleine publieke API serveert. De iOS-app is geschreven in SwiftUI; de webapp gebruikt React Router v7 met MapLibre voor de radarkaart. Alles draait in Docker op één Linux-server."
          }
        }
      }
    },
