# Copy this file to `.env` and fill in your own KNMI keys.
# Never commit `.env` to git — it is in .gitignore.
#
# Each KNMI service issues its own key. Register at:
#   https://developer.dataplatform.knmi.nl/
# All four keys use a bare `Authorization: <key>` header (no `Bearer` prefix).

# Open Data API — file listing + temporary download URLs.
KNMI_OPEN_DATA_API_KEY=

# Notification Service — MQTT 5.0 over WSS/TLS, password = this key.
KNMI_NOTIFICATION_API_KEY=

# Environmental Data Retrieval (EDR) API — OGC-compliant gridded queries.
KNMI_EDR_API_KEY=

# Web Map Service (WMS) — pre-rendered raster layers (fallback / debugging).
KNMI_WMS_API_KEY=

# Public canonical site URL. Used for <link rel="canonical"> and Open Graph tags.
PUBLIC_SITE_URL=https://openweer.nl

# Python service settings (optional).
OPENWEER_LOG_LEVEL=INFO
OPENWEER_DATA_DIR=./data
